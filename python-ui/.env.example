# Python UI 环境变量配置示例
# 复制此文件为 .env 并根据实际环境修改

# ============================================
# Java 服务配置
# ============================================

# Java 服务基础 URL (默认: http://localhost:8080)
JAVA_SERVICE_URL=http://localhost:8080

# Java 服务请求超时时间（秒）(默认: 30)
JAVA_SERVICE_TIMEOUT=30

# ============================================
# 应用配置
# ============================================

# 应用监听主机 (默认: 0.0.0.0)
APP_HOST=0.0.0.0

# 应用监听端口 (默认: 8001)
APP_PORT=8001

# 调试模式 (默认: false)
DEBUG=true

# 应用标题 (默认: Smart Ticket System)
APP_TITLE=Smart Ticket System

# ============================================
# 会话配置
# ============================================

# 会话密钥 (生产环境必须修改)
SESSION_SECRET=default-session-secret-change-in-production

# 会话 Cookie 名称 (默认: session_id)
SESSION_COOKIE_NAME=session_id

# 会话超时时间（分钟）(默认: 60)
SESSION_TIMEOUT_MINUTES=60

# 是否启用安全 Cookie (HTTPS 时启用)
SESSION_SECURE=false

# 是否启用 HttpOnly Cookie (防止 XSS)
SESSION_HTTPONLY=true

# ============================================
# 静态文件配置
# ============================================

# CSS 文件路径 (默认: css)
STATIC_CSS_PATH=css

# JavaScript 文件路径 (默认: js)
STATIC_JS_PATH=js

# 图片文件路径 (默认: images)
STATIC_IMAGES_PATH=images

# ============================================
# CORS 配置
# ============================================

# 允许的源 (逗号分隔，* 表示所有)
CORS_ALLOW_ORIGINS=*

# 是否允许凭证 (默认: true)
CORS_ALLOW_CREDENTIALS=true

# 允许的 HTTP 方法 (逗号分隔)
CORS_ALLOW_METHODS=*

# 允许的 HTTP 头部 (逗号分隔)
CORS_ALLOW_HEADERS=*

# ============================================
# 日志配置
# ============================================

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================
# 开发环境快速配置
# ============================================

# 开发环境快速配置 (取消注释使用)
# DEBUG=true
# JAVA_SERVICE_URL=http://localhost:8080
# APP_PORT=8001
# SESSION_SECRET=dev-secret-key-12345

# ============================================
# 生产环境配置示例
# ============================================

# 生产环境配置 (取消注释使用)
# DEBUG=false
# SESSION_SECURE=true
# SESSION_SECRET=your-strong-random-secret-here
# CORS_ALLOW_ORIGINS=https://your-domain.com